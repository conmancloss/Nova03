{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "headers": [
    { "source": "/(.*)", "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "require-corp" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
    ]},
    { "source": "/scramjet/(.*)", "headers": [{ "key": "Content-Type", "value": "application/javascript" }]},
    { "source": "/scramjet/scramjet.wasm.wasm", "headers": [{ "key": "Content-Type", "value": "application/wasm" }]},
    { "source": "/sw.js", "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
    ]},
    { "source": "/bare-mux-worker.js", "headers": [{ "key": "Content-Type", "value": "application/javascript" }]},
    { "source": "/wisp-transport.mjs", "headers": [{ "key": "Content-Type", "value": "application/javascript" }]}
  ],
  "rewrites": [
    { "source": "/((?!scramjet|sw.js|config.js|bare-mux-worker.js|wisp-transport.mjs|games.json|index.html).*)", "destination": "/index.html" }
  ]
}
